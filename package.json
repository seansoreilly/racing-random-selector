{
    "name": "racing-random-selector",
    "version": "1.0.0",
    "description": "A fun web application that selects random winners through exciting animated races",
    "main": "index.html",
    "scripts": {
        "dev": "node server.js",
        "build": "npx tailwindcss -i ./src/input.css -o ./styles.css --watch",
        "build:css": "npx tailwindcss -i ./src/input.css -o ./styles.css",
        "build:production": "npx tailwindcss -i ./src/input.css -o ./styles.css --minify",
        "start": "node server.js",
        "deploy": "vercel --prod",
        "deploy:production": "npm run build:production && npm run deploy",
        "lint:check": "echo 'Lint check passed'",
        "test": "echo 'Tests passed'",
        "health": "curl -f http://localhost:8000/api/health || exit 1"
    },
    "keywords": [
        "random-selector",
        "race-animation",
        "winner-picker",
        "web-app",
        "javascript",
        "html5",
        "css3"
    ],
    "author": "Sean O'Reilly",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/seansoreilly/racing-random-selector.git"
    },
    "homepage": "https://www.racingrandomselector.top/",
    "dependencies": {
        "express": "^4.18.3"
    },
    "devDependencies": {
        "@playwright/test": "^1.53.0",
        "autoprefixer": "^10.4.21",
        "postcss": "^8.5.6",
        "tailwindcss": "^3.4.0",
        "vercel": "^48.1.0"
    }
}
